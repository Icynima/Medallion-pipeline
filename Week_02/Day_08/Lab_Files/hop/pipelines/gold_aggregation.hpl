<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>gold_aggregation</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Aggregate silver_orders into gold_customer_360 and gold_daily_sales tables using SQL queries. Demonstrates Hop's ability to run aggregation SQL as part of a visual pipeline.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DB_HOST</name>
        <default_value>postgres</default_value>
        <description>PostgreSQL hostname</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user>lab-admin</created_user>
    <created_date>2026/06/08 09:00:00.000</created_date>
    <modified_user>lab-admin</modified_user>
    <modified_date>2026/06/08 09:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>Gold Aggregation Pipeline
Reads silver_orders → Aggregates → Writes to gold tables.
Builds customer_360 and daily_sales gold layer tables.</note>
      <xloc>64</xloc>
      <yloc>32</yloc>
      <width>400</width>
      <heigth>50</heigth>
      <fontname>Noto Sans</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>0</fontcolorred>
      <fontcolorgreen>0</fontcolorgreen>
      <fontcolorblue>0</fontcolorblue>
      <backgroundcolorred>255</backgroundcolorred>
      <backgroundcolorgreen>220</backgroundcolorgreen>
      <backgroundcolorblue>200</backgroundcolorblue>
      <bordercolorred>100</bordercolorred>
      <bordercolorgreen>100</bordercolorgreen>
      <bordercolorblue>100</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Read Silver Orders</from>
      <to>Group By Customer</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Group By Customer</from>
      <to>Classify Segment</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Classify Segment</from>
      <to>Write Gold Customer 360</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Read Silver Orders</from>
      <to>Group By Date</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Group By Date</from>
      <to>Write Gold Daily Sales</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read Silver Orders</name>
    <type>TableInput</type>
    <description>Read all silver_orders for aggregation.</description>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <sql>SELECT order_id, customer_id, product_id, product_name,
       category, quantity, unit_price, total_amount,
       order_date, status
FROM silver_orders</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>256</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Group By Customer</name>
    <type>GroupBy</type>
    <description>Aggregate orders by customer_id.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <all_rows>N</all_rows>
    <ignore_aggregate>N</ignore_aggregate>
    <field_ignore/>
    <directory>${java.io.tmpdir}</directory>
    <prefix>grp</prefix>
    <add_linenr>N</add_linenr>
    <linenr_fieldname/>
    <give_back_row>N</give_back_row>
    <group>
      <field><name>customer_id</name></field>
    </group>
    <fields>
      <field><aggregate>total_orders</aggregate><subject>order_id</subject><type>COUNT_ALL</type><valuefield/></field>
      <field><aggregate>total_revenue</aggregate><subject>total_amount</subject><type>SUM</type><valuefield/></field>
      <field><aggregate>avg_order_value</aggregate><subject>total_amount</subject><type>AVERAGE</type><valuefield/></field>
      <field><aggregate>first_order_date</aggregate><subject>order_date</subject><type>MIN</type><valuefield/></field>
      <field><aggregate>last_order_date</aggregate><subject>order_date</subject><type>MAX</type><valuefield/></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>416</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Classify Segment</name>
    <type>ScriptValueMod</type>
    <description>Assign customer segment based on total revenue.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Segment</jsScript_name>
        <jsScript_script>
var customer_segment;
if (total_revenue >= 200) {
    customer_segment = "Premium";
} else if (total_revenue >= 50) {
    customer_segment = "Regular";
} else {
    customer_segment = "New";
}
var _computed_at = new java.util.Date();
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>customer_segment</name><rename>customer_segment</rename><type>String</type><length>32</length><precision>-1</precision><replace>N</replace></field>
      <field><name>_computed_at</name><rename>_computed_at</rename><type>Date</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write Gold Customer 360</name>
    <type>TableOutput</type>
    <description>Write customer aggregations to gold_customer_360.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <schema>public</schema>
    <table>gold_customer_360</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>N</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields/>
    <attributes/>
    <GUI>
      <xloc>928</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Group By Date</name>
    <type>GroupBy</type>
    <description>Aggregate orders by date for daily sales.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <all_rows>N</all_rows>
    <ignore_aggregate>N</ignore_aggregate>
    <field_ignore/>
    <directory>${java.io.tmpdir}</directory>
    <prefix>grp</prefix>
    <add_linenr>N</add_linenr>
    <linenr_fieldname/>
    <give_back_row>N</give_back_row>
    <group>
      <field><name>order_date</name></field>
    </group>
    <fields>
      <field><aggregate>total_orders</aggregate><subject>order_id</subject><type>COUNT_ALL</type><valuefield/></field>
      <field><aggregate>total_revenue</aggregate><subject>total_amount</subject><type>SUM</type><valuefield/></field>
      <field><aggregate>avg_order_value</aggregate><subject>total_amount</subject><type>AVERAGE</type><valuefield/></field>
      <field><aggregate>unique_customers</aggregate><subject>customer_id</subject><type>COUNT_DISTINCT</type><valuefield/></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>416</xloc>
      <yloc>352</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write Gold Daily Sales</name>
    <type>TableOutput</type>
    <description>Write daily aggregations to gold_daily_sales.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <schema>public</schema>
    <table>gold_daily_sales</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>N</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields/>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>352</yloc>
    </GUI>
  </transform>
</pipeline>
