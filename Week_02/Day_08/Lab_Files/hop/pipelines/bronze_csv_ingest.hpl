<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>bronze_csv_ingest</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Read raw CSV order data and load into the bronze_orders table in PostgreSQL. No transformation – append-only ingestion preserving all original fields.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>INPUT_FILE</name>
        <default_value>${PROJECT_HOME}/data/new_orders.csv</default_value>
        <description>Path to the raw orders CSV file</description>
      </parameter>
      <parameter>
        <name>DB_HOST</name>
        <default_value>postgres</default_value>
        <description>PostgreSQL hostname</description>
      </parameter>
      <parameter>
        <name>DB_PORT</name>
        <default_value>5432</default_value>
        <description>PostgreSQL port</description>
      </parameter>
      <parameter>
        <name>DB_NAME</name>
        <default_value>airflow</default_value>
        <description>Database name</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user>lab-admin</created_user>
    <created_date>2026/06/08 09:00:00.000</created_date>
    <modified_user>lab-admin</modified_user>
    <modified_date>2026/06/08 09:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>Day 8 Lab – Bronze CSV Ingestion Pipeline
Reads raw CSV → validates fields → appends to bronze_orders table.
This pipeline is called by Airflow DAG 07_hop_integration and 09_full_orchestration.</note>
      <xloc>64</xloc>
      <yloc>32</yloc>
      <width>500</width>
      <heigth>60</heigth>
      <fontname>Noto Sans</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>0</fontcolorred>
      <fontcolorgreen>0</fontcolorgreen>
      <fontcolorblue>0</fontcolorblue>
      <backgroundcolorred>255</backgroundcolorred>
      <backgroundcolorgreen>255</backgroundcolorgreen>
      <backgroundcolorblue>200</backgroundcolorblue>
      <bordercolorred>100</bordercolorred>
      <bordercolorgreen>100</bordercolorgreen>
      <bordercolorblue>100</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Read Orders CSV</from>
      <to>Add Load Metadata</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Add Load Metadata</from>
      <to>Validate Fields</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Validate Fields</from>
      <to>Write Bronze Orders</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Validate Fields</from>
      <to>Rejected Records</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read Orders CSV</name>
    <type>CSVInput</type>
    <description>Read the raw orders CSV file with all fields as strings initially.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${INPUT_FILE}</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>order_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>10</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>customer_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>10</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>product_id</name><type>String</type><format/><currency/><decimal/><group/><length>32</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>product_name</name><type>String</type><format/><currency/><decimal/><group/><length>255</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>category</name><type>String</type><format/><currency/><decimal/><group/><length>64</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>quantity</name><type>Integer</type><format/><currency/><decimal/><group/><length>10</length><precision>0</precision><trim_type>both</trim_type></field>
      <field><name>unit_price</name><type>Number</type><format/><currency/><decimal>.</decimal><group/><length>12</length><precision>2</precision><trim_type>both</trim_type></field>
      <field><name>total_amount</name><type>Number</type><format/><currency/><decimal>.</decimal><group/><length>12</length><precision>2</precision><trim_type>both</trim_type></field>
      <field><name>order_date</name><type>String</type><format/><currency/><decimal/><group/><length>10</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>status</name><type>String</type><format/><currency/><decimal/><group/><length>32</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Add Load Metadata</name>
    <type>ScriptValueMod</type>
    <description>Add source identifier and load timestamp.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>AddMetadata</jsScript_name>
        <jsScript_script>
var source = "csv";
var _loaded_at = new java.util.Date();
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>source</name><rename>source</rename><type>String</type><length>32</length><precision>-1</precision><replace>N</replace></field>
      <field><name>_loaded_at</name><rename>_loaded_at</rename><type>Date</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>384</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Validate Fields</name>
    <type>FilterRows</type>
    <description>Filter out records with null order_id or customer_id.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
          <condition>
            <function>IS NOT NULL</function>
            <leftvalue>order_id</leftvalue>
            <negated>N</negated>
            <operator>-</operator>
          </condition>
          <condition>
            <function>IS NOT NULL</function>
            <leftvalue>customer_id</leftvalue>
            <negated>N</negated>
            <operator>AND</operator>
          </condition>
        </conditions>
        <function>IS NOT NULL</function>
        <leftvalue>order_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Write Bronze Orders</send_true_to>
    <send_false_to>Rejected Records</send_false_to>
    <attributes/>
    <GUI>
      <xloc>640</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write Bronze Orders</name>
    <type>TableOutput</type>
    <description>Append validated records to the bronze_orders table.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <schema>public</schema>
    <table>bronze_orders</table>
    <commit>1000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>Y</partitioning_daily>
    <partitioning_monthly>N</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields/>
    <attributes/>
    <GUI>
      <xloc>896</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Rejected Records</name>
    <type>TextFileOutput</type>
    <description>Write rejected records to a CSV file for investigation.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <create_parent_folder>Y</create_parent_folder>
    <file>
      <name>${PROJECT_HOME}/output/rejected_orders</name>
      <servlet_output>N</servlet_output>
      <do_not_open_new_file_init>N</do_not_open_new_file_init>
      <extention>csv</extention>
      <append>Y</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>Y</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields/>
    <attributes/>
    <GUI>
      <xloc>896</xloc>
      <yloc>352</yloc>
    </GUI>
  </transform>
</pipeline>
