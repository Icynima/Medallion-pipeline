<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>silver_transform</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Read from bronze_orders, cleanse, deduplicate, cast types, and write to silver_orders. Filters cancelled orders and zero-quantity rows.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
      <parameter>
        <name>DB_HOST</name>
        <default_value>postgres</default_value>
        <description>PostgreSQL hostname</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user>lab-admin</created_user>
    <created_date>2026/06/08 09:00:00.000</created_date>
    <modified_user>lab-admin</modified_user>
    <modified_date>2026/06/08 09:00:00.000</modified_date>
  </info>
  <notepads>
    <notepad>
      <note>Silver Transformation Pipeline
bronze_orders → Filter → Deduplicate → Type Cast → silver_orders
Called by Airflow DAGs 07 and 09.</note>
      <xloc>64</xloc>
      <yloc>32</yloc>
      <width>420</width>
      <heigth>50</heigth>
      <fontname>Noto Sans</fontname>
      <fontsize>10</fontsize>
      <fontbold>N</fontbold>
      <fontitalic>N</fontitalic>
      <fontcolorred>0</fontcolorred>
      <fontcolorgreen>0</fontcolorgreen>
      <fontcolorblue>0</fontcolorblue>
      <backgroundcolorred>200</backgroundcolorred>
      <backgroundcolorgreen>255</backgroundcolorgreen>
      <backgroundcolorblue>200</backgroundcolorblue>
      <bordercolorred>100</bordercolorred>
      <bordercolorgreen>100</bordercolorgreen>
      <bordercolorblue>100</bordercolorblue>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Read Bronze Orders</from>
      <to>Filter Invalid</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Filter Invalid</from>
      <to>Sort By Order ID</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sort By Order ID</from>
      <to>Deduplicate</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Deduplicate</from>
      <to>Cast Date Fields</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Cast Date Fields</from>
      <to>Add Processing Timestamp</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Add Processing Timestamp</from>
      <to>Write Silver Orders</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Read Bronze Orders</name>
    <type>TableInput</type>
    <description>Read all records from the bronze_orders table.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <sql>SELECT order_id, customer_id, product_id, product_name,
       category, quantity, unit_price, total_amount,
       order_date, status, _loaded_at
FROM bronze_orders
WHERE quantity > 0
  AND status != 'CANCELLED'
ORDER BY order_id, _loaded_at DESC</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Filter Invalid</name>
    <type>FilterRows</type>
    <description>Remove rows with null IDs or negative amounts.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
          <condition>
            <function>IS NOT NULL</function>
            <leftvalue>order_id</leftvalue>
            <negated>N</negated>
            <operator>-</operator>
          </condition>
          <condition>
            <function>&gt;=</function>
            <leftvalue>total_amount</leftvalue>
            <negated>N</negated>
            <operator>AND</operator>
            <value><name>constant</name><type>Number</type><text>0</text></value>
          </condition>
        </conditions>
        <function>IS NOT NULL</function>
        <leftvalue>order_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_true_to>Sort By Order ID</send_true_to>
    <send_false_to/>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sort By Order ID</name>
    <type>SortRows</type>
    <description>Sort by order_id for deduplication.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <directory>${java.io.tmpdir}</directory>
    <prefix>sort</prefix>
    <sort_size>100000</sort_size>
    <free_memory/>
    <compress>N</compress>
    <compress_variable/>
    <unique_rows>N</unique_rows>
    <fields>
      <field><name>order_id</name><ascending>Y</ascending><case_sensitive>N</case_sensitive><collator_enabled>N</collator_enabled><collator_strength>0</collator_strength><presorted>N</presorted></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>544</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Deduplicate</name>
    <type>Unique</type>
    <description>Keep only the first occurrence of each order_id (latest load wins due to sort).</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_rows>N</count_rows>
    <count_field/>
    <reject_duplicate_row>N</reject_duplicate_row>
    <error_description/>
    <fields>
      <field><name>order_id</name><case_insensitive>N</case_insensitive></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>736</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Cast Date Fields</name>
    <type>SelectValues</type>
    <description>Select and rename fields for the silver table.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field><name>order_id</name></field>
      <field><name>customer_id</name></field>
      <field><name>product_id</name></field>
      <field><name>product_name</name></field>
      <field><name>category</name></field>
      <field><name>quantity</name></field>
      <field><name>unit_price</name></field>
      <field><name>total_amount</name></field>
      <field><name>order_date</name></field>
      <field><name>status</name></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <meta>
      <changes>
        <change><name>order_date</name><rename>order_date</rename><type>Date</type><length>-2</length><precision>-2</precision><conversion_mask>yyyy-MM-dd</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>false</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/></change>
      </changes>
    </meta>
    <attributes/>
    <GUI>
      <xloc>928</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Add Processing Timestamp</name>
    <type>ScriptValueMod</type>
    <description>Add processing timestamp for silver layer.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>AddTimestamp</jsScript_name>
        <jsScript_script>var _processed_at = new java.util.Date();</jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>_processed_at</name><rename>_processed_at</rename><type>Date</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>1152</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write Silver Orders</name>
    <type>TableOutput</type>
    <description>Write cleansed, deduplicated records to silver_orders.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>warehouse</connection>
    <schema>public</schema>
    <table>silver_orders</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>N</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields/>
    <attributes/>
    <GUI>
      <xloc>1376</xloc>
      <yloc>192</yloc>
    </GUI>
  </transform>
</pipeline>
