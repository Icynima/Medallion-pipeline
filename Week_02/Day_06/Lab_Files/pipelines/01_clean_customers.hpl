<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>01_clean_customers</name>
    <name_sync_with_filename>N</name_sync_with_filename>
    <description>Clean customer data, normalize strings, reject invalid rows, sort, and deduplicate.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user>-</created_user>
    <created_date/>
    <modified_user>-</modified_user>
    <modified_date/>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Read Customers</from>
      <to>Normalize Fields</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Normalize Fields</from>
      <to>Keep Valid Customers</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Keep Valid Customers</from>
      <to>Sort By Customer</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Sort By Customer</from>
      <to>Unique Customers</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Unique Customers</from>
      <to>Customers Cleaned CSV</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Keep Valid Customers</from>
      <to>Rejected Customers</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Customers Cleaned CSV</name>
    <type>TextFileOutput</type>
    <description>Write cleaned customer records.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <schema_definition/>
    <ignore_fields>N</ignore_fields>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <create_parent_folder>Y</create_parent_folder>
    <file>
      <name>${PROJECT_HOME}/output/customers_cleaned</name>
      <servlet_output>N</servlet_output>
      <do_not_open_new_file_init>N</do_not_open_new_file_init>
      <extention>csv</extention>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields>
    </fields>
    <attributes/>
    <GUI>
      <xloc>1260</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Keep Valid Customers</name>
    <type>FilterRows</type>
    <description>Route rows with an email to the clean path and blanks to the reject file.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compare>
      <condition>
        <conditions>
</conditions>
        <function>IS NOT NULL</function>
        <leftvalue>email_clean</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_false_to>Rejected Customers</send_false_to>
    <send_true_to>Sort By Customer</send_true_to>
    <attributes/>
    <GUI>
      <xloc>540</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Normalize Fields</name>
    <type>ScriptValueMod</type>
    <description>Trim names, lower-case email, normalize country and phone fields.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Normalize</jsScript_name>
        <jsScript_script>
var customer_name = name == null ? "" : String(name).trim();
var email_clean = email == null || String(email).trim() == "" ? null : String(email).trim().toLowerCase();
var country_normalized = country == null ? "" : String(country).trim().toUpperCase();
var phone_normalized = phone == null ? "" : String(phone).trim();
if (phone_normalized.indexOf("00") == 0) {
  phone_normalized = "+" + phone_normalized.substring(2);
}
var processed_at = new Date();
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>customer_name</name>
        <rename>customer_name</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>email_clean</name>
        <rename>email_clean</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>country_normalized</name>
        <rename>country_normalized</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>phone_normalized</name>
        <rename>phone_normalized</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>processed_at</name>
        <rename>processed_at</rename>
        <type>Date</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>300</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Read Customers</name>
    <type>CSVInput</type>
    <description>Read raw customer records.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <filename>${PROJECT_HOME}/data/customers.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <ignoreFields>N</ignoreFields>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>Y</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field>
        <name>customer_id</name>
        <type>Integer</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>0</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>name</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>email</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>phone</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>country</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>both</trim_type>
      </field>
      <field>
        <name>order_amount</name>
        <type>Number</type>
        <format>0.00</format>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>2</precision>
        <trim_type>both</trim_type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>80</xloc>
      <yloc>240</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Rejected Customers</name>
    <type>TextFileOutput</type>
    <description>Write rejected customer records for inspection.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <schema_definition/>
    <ignore_fields>N</ignore_fields>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <enclosure_forced>N</enclosure_forced>
    <enclosure_fix_disabled>N</enclosure_fix_disabled>
    <header>Y</header>
    <footer>N</footer>
    <format>DOS</format>
    <compression>None</compression>
    <encoding>UTF-8</encoding>
    <endedLine/>
    <fileNameInField>N</fileNameInField>
    <fileNameField/>
    <create_parent_folder>Y</create_parent_folder>
    <file>
      <name>${PROJECT_HOME}/output/customers_rejected</name>
      <servlet_output>N</servlet_output>
      <do_not_open_new_file_init>N</do_not_open_new_file_init>
      <extention>csv</extention>
      <append>N</append>
      <split>N</split>
      <haspartno>N</haspartno>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <SpecifyFormat>N</SpecifyFormat>
      <date_time_format/>
      <add_to_result_filenames>Y</add_to_result_filenames>
      <pad>N</pad>
      <fast_dump>N</fast_dump>
      <splitevery/>
    </file>
    <fields>
    </fields>
    <attributes/>
    <GUI>
      <xloc>780</xloc>
      <yloc>360</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Sort By Customer</name>
    <type>SortRows</type>
    <description>Sort before Unique Rows.</description>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compress>N</compress>
    <directory>${PROJECT_HOME}/output</directory>
    <fields>
      <field>
        <ascending>Y</ascending>
        <case_sensitive>N</case_sensitive>
        <collator_enabled>N</collator_enabled>
        <collator_strength>0</collator_strength>
        <name>customer_id</name>
        <presorted>N</presorted>
      </field>
    </fields>
    <sort_size>1000000</sort_size>
    <unique_rows>N</unique_rows>
    <attributes/>
    <GUI>
      <xloc>780</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Unique Customers</name>
    <type>Unique</type>
    <description>Keep one record per customer_id and count duplicate rows.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <count_field>duplicate_count</count_field>
    <count_rows>Y</count_rows>
    <error_description/>
    <fields>
      <field>
        <case_insensitive>N</case_insensitive>
        <name>customer_id</name>
      </field>
    </fields>
    <reject_duplicate_row>N</reject_duplicate_row>
    <attributes/>
    <GUI>
      <xloc>1020</xloc>
      <yloc>160</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
